# Pro lokální testování ve VS Code (node scripts/check.js).
# Na GitHubu se webhook NIKDY nedává sem, ale jako repository secret
# (Settings -> Secrets and variables -> Actions -> New repository secret,
# název: DISCORD_WEBHOOK_URL).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/VAS_WEBHOOK_ID/VAS_WEBHOOK_TOKEN

# Volitelné - CSS selector přesné oblasti rozvrhu (viz README, jak ho zjistit)
TIMETABLE_SELECTOR=body
